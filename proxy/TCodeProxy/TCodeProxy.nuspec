<?xml version="1.0"?>
<package>
  <metadata>
    <id>TCodeProxy</id>
    <version>1.0.0</version>
    <title>TCodeProxy</title>
    <authors>T-Code</authors>
    <owners>T-Code</owners>
    <licenseUrl>https://opensource.org/licenses/MIT</licenseUrl>
    <projectUrl>https://github.com/your-org/T-Code-IME-for-Win</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/your-org/T-Code-IME-for-Win/main/proxy/icons/icon.ico</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Proxy host for the T-Code IME, including gRPC client and tray UI.</description>
    <releaseNotes>Initial NuGet package for TCodeProxy.</releaseNotes>
    <tags>IME gRPC proxy TCode Windows</tags>
    <dependencies>
      <dependency id="Google.Protobuf" version="3.34.1" />
      <dependency id="Grpc.Net.Client" version="2.80.0" />
      <dependency id="Grpc.Tools" version="2.80.0" />
    </dependencies>
  </metadata>
  <files>
    <file src="build\Release\TCodeIME.dll" target="tools" />
    <file src="proxy\TCodeProxy\bin\Release\net10.0-windows\TCodeProxy.exe" target="tools" />
    <file src="proxy\TCodeProxy\bin\Release\net10.0-windows\*.deps.json" target="tools" />
    <file src="proxy\TCodeProxy\bin\Release\net10.0-windows\*.runtimeconfig.json" target="tools" />
    <file src="proxy\TCodeProxy\bin\Release\net10.0-windows\*.dll" target="tools" exclude="TCodeProxy.exe" />
    <file src="proxy\TCodeProxy\bin\Release\net10.0-windows\icon.ico" target="tools" />
  </files>
</package>
