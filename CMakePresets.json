{
  "version": 6,
  "configurePresets": [
    {
      "name": "base-windows",
      "description": "Abstract base setting for the MSVC Toolchain",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "win32",
      "inherits": "base-windows",
      "architecture": { "value": "Win32", "strategy": "set" },
      "toolset": { "value": "v143,host=x64", "strategy": "set" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x86-windows"
      },
      "binaryDir": "${sourceDir}/build/win32"
    },
    {
      "name": "x64",
      "inherits": "base-windows",
      "architecture": { "value": "x64", "strategy": "set" },
      "toolset": { "value": "v143,host=x64", "strategy": "set" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      },
      "binaryDir": "${sourceDir}/build/x64"
    },
    {
      "name": "x64-java-runtime",
      "inherits": "base-windows",
      "architecture": { "value": "x64", "strategy": "set" },
      "toolset": { "value": "v143,host=x64", "strategy": "set" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "TCODE_BUNDLE_JRE": "ON",
        "TCODE_JLINK_MODULES": "java.base,java.logging,java.sql,java.naming,java.management,java.xml,jdk.unsupported,jdk.zipfs,jdk.charsets,java.net.http,java.scripting,java.instrument,java.security.jgss,java.security.sasl,java.datatransfer,java.desktop,jdk.crypto.ec,jdk.crypto.cryptoki,jdk.crypto.mscapi,jdk.localedata,jdk.management,jdk.management.agent,jdk.naming.dns,jdk.naming.rmi,jdk.sctp,jdk.security.auth,jdk.security.jgss"
      },
      "binaryDir": "${sourceDir}/build/x64-java-runtime"
    },
    {
      "name": "arm64",
      "inherits": "base-windows",
      "architecture": { "value": "ARM64", "strategy": "set" },
      "toolset": { "value": "v143,host=x64", "strategy": "set" },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-windows",
        "CMAKE_CXX_FLAGS": "/Qspectre /EHsc"
      },
      "binaryDir": "${sourceDir}/build/arm64"
    }
  ],
  "buildPresets": [
    {
      "name": "base-build",
      "hidden": true,
      "configuration": "Release"
    },
    {
      "name": "artifacts-win32",
      "inherits": "base-build",
      "configurePreset": "win32",
      "targets": [ "BuildInnoInstaller" ]
    },
    {
      "name": "artifacts-x64",
      "inherits": "base-build",
      "configurePreset": "x64",
      "targets": [ "BuildInnoInstaller" ]
    },
    {
      "name": "artifacts-x64-java-runtime",
      "inherits": "base-build",
      "configurePreset": "x64-java-runtime",
      "targets": [ "BuildInnoInstaller" ]
    },
    {
      "name": "artifacts-arm64",
      "inherits": "base-build",
      "configurePreset": "arm64",
      "targets": [ "BuildInnoInstaller" ]
    },
    {
      "name": "winget",
      "inherits": "base-build",
      "configurePreset": "x64",
      "targets": [ "GenerateWingetManifests" ]
    }
  ]
}
